# ─────────────────────────────────────────────
# AI CONTENT SYSTEM — Environment Variables
# Copy this file to .env and fill in your keys
# ─────────────────────────────────────────────

# ANTHROPIC (Claude API)
# Get from: console.anthropic.com
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# NEWS API
# Get from: newsapi.org (free tier = 100 req/day)
NEWS_API_KEY=your_newsapi_key_here

# CANVA API
# Get from: canva.com/developers → Connect API
CANVA_CLIENT_ID=your_canva_client_id_here
CANVA_CLIENT_SECRET=your_canva_client_secret_here
CANVA_ACCESS_TOKEN=your_canva_access_token_here

# CLOUDINARY (image hosting for Instagram)
# Get from: cloudinary.com → free account
CLOUDINARY_CLOUD_NAME=your_cloud_name_here
CLOUDINARY_API_KEY=your_cloudinary_api_key_here
CLOUDINARY_API_SECRET=your_cloudinary_api_secret_here

# X (TWITTER) API
# Get from: developer.twitter.com → Create App
# Need: Free tier (1500 posts/month)
X_API_KEY=your_x_api_key_here
X_API_SECRET=your_x_api_secret_here
X_ACCESS_TOKEN=your_x_access_token_here
X_ACCESS_TOKEN_SECRET=your_x_access_token_secret_here

# LINKEDIN API
# Get from: linkedin.com/developers → Create App (attach Company Page)
LINKEDIN_CLIENT_ID=your_linkedin_client_id_here
LINKEDIN_CLIENT_SECRET=your_linkedin_client_secret_here
LINKEDIN_ACCESS_TOKEN=your_linkedin_access_token_here
LINKEDIN_ORGANIZATION_ID=your_linkedin_org_id_here

# INSTAGRAM / META API
# Get from: developers.facebook.com → Instagram Graph API
# Requires: Business/Creator account + connected Facebook Page
INSTAGRAM_ACCESS_TOKEN=your_instagram_access_token_here
INSTAGRAM_BUSINESS_ACCOUNT_ID=your_instagram_business_account_id_here

# BRAND CONFIG
BRAND_NAME=YourBrandName
BRAND_NICHE=AI Career & Tools
BRAND_TONE=confident, sharp, career-focused
